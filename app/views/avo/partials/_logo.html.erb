<% branding = Avo.configuration.branding %>

<%= link_to avo.root_path, class: "logo-placeholder h-full w-full block justify-start" do %>
  <picture class="hidden h-full object-contain sm:block">
    <% if branding.logo_dark.present? %>
      <source srcset="<%= asset_path branding.logo_dark %>" media="(prefers-color-scheme: dark)">
    <% end %>

    <%= image_tag branding.logo, class: "object-contain h-full", title: "Avo" %>
  </picture>

  <picture class="h-full object-contain sm:hidden">
    <% if branding.logomark_dark.present? %>
      <source srcset="<%= asset_path branding.logomark_dark %>" media="(prefers-color-scheme: dark)">
    <% end %>

    <%= image_tag branding.logomark, class: "object-contain h-full", title: "Avo" %>
  </picture>
<% end %>
