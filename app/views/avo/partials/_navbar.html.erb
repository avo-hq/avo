<%
  sidebar_open_icon = 'layout-sidebar-left-collapse'
  sidebar_closed_icon = 'layout-sidebar-left-expand'
  sidebar_state = @sidebar_open ? 'open' : 'closed'
%>
<%= content_tag :nav, class: class_names("top-navbar", {"print:hidden": Avo.configuration.hide_layout_when_printing}) do %>
  <%# Spacer matching the sidebar width so breadcrumbs/search start where the content area starts.
      The sidebar itself sits on top of this area via a higher z-index. %>
  <div class="top-navbar__spacer" aria-hidden="true"></div>

  <div class="top-navbar__content">
    <%# Mobile-only toggle: the sidebar is hidden by default on mobile so we need a way to open it. %>
    <%= a_button class: 'lg:hidden shrink-0',
                 size: :sm,
                 style: :text,
                 data: {
                   action: 'click->sidebar#toggleSidebarOnMobile',
                   sidebar_toggle_icon: true,
                   sidebar_state: sidebar_state
                 },
                 aria: { label: "Toggle sidebar" } do %>
      <span class="sidebar-toggle-icon sidebar-toggle-icon--open">
        <%= svg sidebar_open_icon, class: 'h-4 button__icon' %>
      </span>
      <span class="sidebar-toggle-icon sidebar-toggle-icon--closed">
        <%= svg sidebar_closed_icon, class: 'h-4 button__icon' %>
      </span>
    <% end %>

    <%# Desktop-only toggle: only visible when the sidebar is closed (the sidebar header
        owns the toggle while open, but slides off-screen when closed). %>
    <% if Avo.configuration.sidebar_toggle_visible %>
      <%= a_button class: 'top-navbar__sidebar-toggle shrink-0',
                   size: :sm,
                   style: :text,
                   data: {
                     action: 'click->sidebar#toggleSidebar',
                     sidebar_toggle_icon: true,
                     sidebar_state: sidebar_state
                   },
                   aria: { label: "Open sidebar" } do %>
        <%= svg sidebar_closed_icon, class: 'h-4 button__icon' %>
      <% end %>
    <% end %>

    <div class="flex-1 min-w-0">
      <%= render Avo::BreadcrumbsComponent.new(items: avo_breadcrumbs) %>
    </div>
    <div class="flex items-center gap-4 h-full m-0">
      <%= render partial: "avo/partials/header" %>
      <%= render partial: "avo/partials/color_scheme_switcher" %>
    </div>
  </div>
<% end %>
