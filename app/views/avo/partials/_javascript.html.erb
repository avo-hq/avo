<%= javascript_tag nonce: true do %>
  window.Avo = window.Avo || { configuration: {} }
  Avo.configuration.timezone = '<%= Avo.configuration.timezone %>'
  Avo.configuration.root_path = '<%= root_path_without_url %>'
  Avo.configuration.search_debounce = '<%= Avo.configuration.search_debounce %>'
  Avo.configuration.cookies_key = '<%= Avo::COOKIES_KEY %>'
  <% if Avo.avo_dynamic_filters_installed? %>
  Avo.configuration.avo_filters = {
    param_key: '<%= Avo::DynamicFilters.configuration.param_key %>'
  }
  <% end %>
  Avo.configuration.modal_frame_id = '<%= ::Avo::MODAL_FRAME_ID %>'
  Avo.configuration.stimulus_controllers = []
  Avo.configuration.hotkeys = {
    enabled: <%= Avo.configuration.hotkeys[:enabled] %>,
    showKeyBadges: <%= Avo.configuration.hotkeys[:show_key_badges] %>
  }
  Avo.configuration.media_library = {
    enabled: <%= Avo::MediaLibrary.configuration.enabled? %>,
    visible: <%= Avo::MediaLibrary.configuration.visible? %>
  }
  Avo.configuration.appearance = {
    persistence: '<%= Avo.configuration.appearance.persistence %>',
    scheme: '<%= Avo.configuration.appearance.scheme %>',
    neutral: '<%= Avo.configuration.appearance.neutral_css_class %>',
    accent: '<%= Avo.configuration.appearance.accent_css_class %>',
    schemeLocked: <%= Avo.configuration.appearance.scheme_locked? %>,
    neutralLocked: <%= Avo.configuration.appearance.neutral_locked? %>,
    accentLocked: <%= Avo.configuration.appearance.accent_locked? %>,
    neutrals: <%== Avo.configuration.appearance.neutrals.as_json %>,
    accents: <%== Avo.configuration.appearance.accents.as_json %>
  }
<% end %>
