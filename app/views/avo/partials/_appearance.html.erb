<% if Avo.configuration.appearance.favicon_dark.present? %>
  <%= favicon_link_tag Avo.configuration.appearance.favicon,
    data: {
      controller: "theme-favicon",
      theme_favicon_light_url_value: asset_path(Avo.configuration.appearance.favicon),
      theme_favicon_dark_url_value: asset_path(Avo.configuration.appearance.favicon_dark)
    } %>
<% else %>
  <%= favicon_link_tag Avo.configuration.appearance.favicon %>
<% end %>
