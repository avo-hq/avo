<% if Avo.configuration.branding.database_persistence? && Avo::Current.theme_settings.present? %>
  <script nonce="<%= content_security_policy_nonce %>">
    window.__avoThemeSettings__ = <%= Avo::Current.theme_settings.to_json.html_safe %>;
  </script>
<% end %>

<script nonce="<%= content_security_policy_nonce %>">
  // On page load, apply color scheme, theme, and accent to avoid FOUC
  (function() {
    function getCookie(name) {
      const value = `; ${document.cookie}`;
      const parts = value.split(`; ${name}=`);
      if (parts.length === 2) return parts.pop().split(';').shift();
      return null;
    }

    const branding = document.querySelector('meta[name="avo-branding"]')?.dataset || {};
    const isStatic = branding.mode === 'static';
    const dbSettings = window.__avoThemeSettings__ || null;

    const colorScheme = dbSettings?.color_scheme
      || getCookie('color_scheme')
      || branding.defaultScheme || 'auto';

    const theme = isStatic && branding.lockedNeutral
      ? branding.lockedNeutral
      : (dbSettings?.neutral || getCookie('theme') || 'brand');

    const accent = isStatic && branding.lockedAccent
      ? branding.lockedAccent
      : (dbSettings?.accent || getCookie('accent_color') || 'neutral');

    // Apply color scheme
    const isDark = colorScheme === 'dark' || (colorScheme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    if (isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    // Apply scheme selection classes
    document.documentElement.classList.remove('scheme-light', 'scheme-dark', 'scheme-auto');
    if (colorScheme === 'light') {
      document.documentElement.classList.add('scheme-light');
    } else if (colorScheme === 'dark') {
      document.documentElement.classList.add('scheme-dark');
    } else {
      document.documentElement.classList.add('scheme-auto');
    }

    // Apply theme class
    document.documentElement.classList.remove('theme-slate', 'theme-stone', 'theme-gray', 'theme-zinc', 'theme-neutral', 'theme-taupe', 'theme-mauve', 'theme-mist', 'theme-olive');
    if (theme && theme !== 'brand') {
      document.documentElement.classList.add('theme-' + theme);
    }

    // Apply accent class
    const accentColors = <%= accent_colors.inspect.html_safe %>;
    accentColors.forEach((color) => {
      document.documentElement.classList.remove('accent-' + color);
    });
    if (accent && accent !== 'neutral') {
      document.documentElement.classList.add('accent-' + accent);
    }
  })();
</script>
