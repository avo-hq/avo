<script nonce="<%= content_security_policy_nonce %>">
  // Apply color scheme and theme classes before paint to avoid FOUC.
  // Static mode and database-persisted settings are already server-rendered
  // on <html>. This script handles localStorage overrides and "auto" dark mode.
  (function() {
    var root = document.documentElement;

    <% branding = Avo.configuration.branding %>

    <% unless branding.static? %>
      <% unless branding.database_persistence? %>
        // Dynamic + localStorage: apply user preferences from cookies
        function getCookie(name) {
          var value = '; ' + document.cookie;
          var parts = value.split('; ' + name + '=');
          if (parts.length === 2) return parts.pop().split(';').shift();
          return null;
        }

        var theme = getCookie('theme');
        if (theme && theme !== 'brand') {
          root.classList.remove(<%= %w[slate stone gray zinc neutral taupe mauve mist olive].map { |n| "'theme-neutral-#{n}'" }.join(", ") %>);
          root.classList.add('theme-neutral-' + theme);
        }

        var accent = getCookie('accent_color');
        if (accent && accent !== 'neutral') {
          <%= accent_colors.map { |c| "root.classList.remove('theme-accent-#{c}');" }.join("\n          ") %>
          root.classList.add('theme-accent-' + accent);
        }

        var scheme = getCookie('color_scheme');
        if (scheme) {
          root.classList.remove('scheme-light', 'scheme-dark', 'scheme-auto');
          root.classList.add('scheme-' + scheme);
          if (scheme === 'dark') {
            root.classList.add('dark');
          } else if (scheme === 'light') {
            root.classList.remove('dark');
          }
        }
      <% end %>
    <% end %>

    // Handle "auto" scheme — always needs JS for media query detection
    if (root.classList.contains('scheme-auto')) {
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    }
  })();
</script>
