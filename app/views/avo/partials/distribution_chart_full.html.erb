<% content_for :head do %>
  <% set_meta_tags title: @page_title %>
<% end %>

<%= render ui.panel(
  title: "#{@resource.plural_name.humanize} summary",
  description: "Distribution by \"#{@field_id.to_s.humanize.downcase}\""
) do |panel| %>
  <% panel.with_controls do %>
    <%= a_link @back_path,
      style: :text,
      title: t("avo.go_back"),
      icon: "tabler/outline/arrow-left",
      data: { hotkey: "b", tippy: :tooltip } do %>
      <%= t("avo.go_back") %>
    <% end %>
  <% end %>

  <% panel.with_card do %>
    <div class="distribution-chart__body">
      <%= pie_chart @values_summary, id: "chart-full-#{@field_id}", legend: false, height: "360px", colors: Avo.configuration.branding.chart_colors %>
    </div>
  <% end %>

  <%= panel.with_sidebar do %>
    <%= render ui.card(
      title: "Breakdown",
      class: "w-full self-start distribution-chart__sidecard",
      data: {
        controller: "distribution-chart",
        distribution_chart_chart_id_value: "chart-full-#{@field_id}"
      }
    ) do %>
      <div class="distribution-chart__grid" id="<%= @field_id %>-full-summary">
        <% total = @values_summary.values.sum.to_f %>
        <% @values_summary.each_with_index do |(key, value), index| %>
          <button type="button"
            class="distribution-chart__row"
            data-action="click->distribution-chart#toggleSlice mouseenter->distribution-chart#highlightSlice mouseleave->distribution-chart#clearHighlight"
            data-distribution-chart-index-param="<%= index %>">
            <%= tag.span class: class_names("distribution-chart__color", "bg-[#{chart_color(index)}]") %>
            <span class="distribution-chart__key"><%= key %></span>
            <span class="distribution-chart__value">
              <%= pluralize(value, @resource.singular_name.downcase, plural: @resource.plural_name.downcase) %>
            </span>
            <span class="distribution-chart__percentage">
              <%= total > 0 ? number_to_percentage((value / total) * 100, precision: 1) : "0%" %>
            </span>
          </button>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
