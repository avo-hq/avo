<%
  icon = "tabler/outline/selector"

  if params[:sort_by] == field.id.to_s
    case params[:sort_direction]
      when 'asc'
        icon = "tabler/outline/sort-ascending"
      when 'desc'
        icon = "tabler/outline/sort-descending"
      end
  end
%>
<%= svg icon,
  class: 'inline-block fill-current text-gray-500 relative leading-none min-w-[1rem] min-h-full ms-1 h-4',
  data: {
    tippy: :tooltip,
    tippy_content: sort_tippy_content
  }
%>
