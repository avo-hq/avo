<% branding = Avo.configuration.branding %>
<% show_neutral_picker = !branding.neutral_locked? %>
<% show_accent_picker = !branding.accent_locked? %>
<% show_scheme_picker = !branding.scheme_locked? %>
<% return unless show_neutral_picker || show_accent_picker || show_scheme_picker %>
<% active_neutral = current_neutral %>
<% active_accent = current_accent %>
<div class="color-scheme-switcher"
     data-controller="color-scheme-switcher">
  <% if show_neutral_picker %>
    <%= render Avo::UI::DropdownComponent.new(
      classes: "color-scheme-switcher__theme-popover"
    ) do |component| %>
      <% component.with_trigger do %>
        <button type="button"
                data-action="<%= component.action %>"
                class="color-scheme-switcher__button color-scheme-switcher__button--theme"
                title="Neutrals theme">
          <span class="color-scheme-switcher__text" data-color-scheme-switcher-target="themeLabel"><%= active_neutral.capitalize %></span>
        </button>
      <% end %>
      <% component.with_items do %>
        <div class="color-scheme-switcher__theme-options"
             data-action="mouseleave->color-scheme-switcher#revertTheme">
          <% (["brand"] + branding.neutrals).each do |theme| %>
            <button type="button"
                    data-action="click->color-scheme-switcher#setTheme click->dropdown-menu#close mouseenter->color-scheme-switcher#previewTheme"
                    data-theme="<%= theme %>"
                    data-color-scheme-switcher-target="themeOption"
                    class="<%= class_names("color-scheme-switcher__theme-option", "color-scheme-switcher__theme-option--active": theme == active_neutral) %>">
              <span class="color-scheme-switcher__theme-preview color-scheme-switcher__theme-preview--<%= theme %>"></span>
              <span class="color-scheme-switcher__theme-option-label"><%= theme.capitalize %></span>
            </button>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if show_accent_picker %>
    <%= render Avo::UI::DropdownComponent.new(
      classes: "color-scheme-switcher__accent-popover"
    ) do |component| %>
      <% component.with_trigger do %>
        <button type="button"
                data-color-scheme-switcher-target="button"
                data-action="<%= component.action %>"
                class="color-scheme-switcher__button color-scheme-switcher__button--accent"
                title="Accent color">
          <%= svg "tabler/outline/color-swatch", class: "color-scheme-switcher__icon" %>
          <span class="color-scheme-switcher__accent-badge">
            <span class="color-scheme-switcher__accent-badge-preview color-scheme-switcher__accent-badge-preview--neutral"></span>
            <% branding.accents.each do |accent| %>
              <span class="color-scheme-switcher__accent-badge-preview color-scheme-switcher__accent-badge-preview--<%= accent %> bg-<%= accent %>-500"></span>
            <% end %>
          </span>
          <span class="sr-only">Accent color</span>
        </button>
      <% end %>
      <% component.with_items do %>
        <div class="color-scheme-switcher__accent-options"
             data-action="mouseleave->color-scheme-switcher#revertAccent">
          <% (['neutral'] + branding.accents).each do |accent| %>
            <%
              preview_class = if accent == "neutral"
                "color-scheme-switcher__accent-preview color-scheme-switcher__accent-preview--neutral"
              else
                "color-scheme-switcher__accent-preview bg-#{accent}-500"
              end
            %>
            <button type="button"
                    data-action="click->color-scheme-switcher#setAccent click->dropdown-menu#close mouseenter->color-scheme-switcher#previewAccent"
                    data-accent="<%= accent %>"
                    data-color-scheme-switcher-target="accentOption"
                    class="<%= class_names("color-scheme-switcher__accent-option", "color-scheme-switcher__accent-option--active": accent == active_accent) %>">
              <span class="<%= preview_class %>"></span>
              <span class="sr-only"><%= accent.capitalize %></span>
            </button>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if show_scheme_picker %>
    <button type="button"
            data-color-scheme-switcher-target="button"
            data-action="click->color-scheme-switcher#setScheme"
            data-scheme="auto"
            class="color-scheme-switcher__button"
            title="Auto (system preference)">
      <%= svg "tabler/outline/device-desktop", class: "color-scheme-switcher__icon" %>
      <span class="sr-only">Auto</span>
    </button>
    <button type="button"
            data-color-scheme-switcher-target="button"
            data-action="click->color-scheme-switcher#setScheme"
            data-scheme="light"
            class="color-scheme-switcher__button"
            title="Light mode">
      <%= svg "tabler/outline/sun", class: "color-scheme-switcher__icon" %>
      <span class="sr-only">Light</span>
    </button>
    <button type="button"
            data-color-scheme-switcher-target="button"
            data-action="click->color-scheme-switcher#setScheme"
            data-scheme="dark"
            class="color-scheme-switcher__button"
            title="Dark mode">
      <%= svg "tabler/outline/moon", class: "color-scheme-switcher__icon" %>
      <span class="sr-only">Dark</span>
    </button>
  <% end %>
</div>

