<%= content_tag :div, class: class_names("dropdown-card", @classes) do %>
  <% if header? %>
  <div class="dropdown-card__header">
      <%= header %>
    </div>
  <% end %>

  <div class="dropdown-card__body">
    <%= body %>
  </div>

  <% if footer? %>
    <div class="dropdown-card__footer">
      <%= footer %>
    </div>
  <% end %>
<% end %>
