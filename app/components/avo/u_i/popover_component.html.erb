<%= tag.div class: class_names("popover-dialog", @classes),
  popover: "auto",
  id: @id,
  style: computed_style,
  data: @data do %>
  <% if header? %>
    <div class="popover__header">
      <%= header %>
    </div>
  <% end %>

  <% if body_content.present? %>
    <div class="popover__body">
      <%= body_content %>
    </div>
  <% end %>

  <% if footer? %>
    <div class="popover__footer">
      <%= footer %>
    </div>
  <% end %>
<% end %>
