<div class="absolute bg-secondary dark:bg-tertiary size-full content-center">
  <%# Decorative icons — purely visual, hidden from screen readers %>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-3 start-4 rotate-12" style="animation-duration:3.8s;animation-delay:0s;color:color-mix(in srgb,var(--color-content) 15%,transparent)">
    <%= helpers.svg "tabler/outline/star", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-4 end-5 -rotate-12" style="animation-duration:4.2s;animation-delay:0.4s;color:color-mix(in srgb,var(--color-content) 18%,transparent)">
    <%= helpers.svg "tabler/outline/bolt", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-[calc(50%-8px)] start-3" style="animation-duration:3.5s;animation-delay:0.8s;color:color-mix(in srgb,var(--color-content) 13%,transparent)">
    <%= helpers.svg "tabler/outline/clock", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-3 start-8 rotate-6" style="animation-duration:4.6s;animation-delay:1.2s;color:color-mix(in srgb,var(--color-content) 20%,transparent)">
    <%= helpers.svg "tabler/outline/heart", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-6 start-1/3 -rotate-6" style="animation-duration:3.2s;animation-delay:1.6s;color:color-mix(in srgb,var(--color-content) 16%,transparent)">
    <%= helpers.svg "tabler/outline/leaf", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-4 end-5 rotate-12" style="animation-duration:4.8s;animation-delay:2.0s;color:color-mix(in srgb,var(--color-content) 14%,transparent)">
    <%= helpers.svg "tabler/outline/sparkles", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-3 end-10 -rotate-6" style="animation-duration:3.6s;animation-delay:2.4s;color:color-mix(in srgb,var(--color-content) 19%,transparent)">
    <%= helpers.svg "tabler/outline/rocket", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-3 end-12 rotate-6" style="animation-duration:4.4s;animation-delay:2.8s;color:color-mix(in srgb,var(--color-content) 17%,transparent)">
    <%= helpers.svg "tabler/outline/diamond", class: "size-4" %>
  </span>

  <%= svg Avo.configuration.branding.placeholder, class: "relative mx-auto h-20 text-content-secondary" %>
</div>
