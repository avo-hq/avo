<div class="absolute bg-secondary dark:bg-tertiary size-full content-center">
  <%# Decorative icons — purely visual, hidden from screen readers %>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-3 start-4 rotate-12 text-amber-400/40" style="animation-duration:3.8s;animation-delay:0s">
    <%= helpers.svg "tabler/outline/star", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-4 end-5 -rotate-12 text-blue-400/40" style="animation-duration:4.2s;animation-delay:0.4s">
    <%= helpers.svg "tabler/outline/bolt", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-[calc(50%-8px)] start-3 text-slate-400/40" style="animation-duration:3.5s;animation-delay:0.8s">
    <%= helpers.svg "tabler/outline/clock", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-3 start-8 rotate-6 text-rose-400/40" style="animation-duration:4.6s;animation-delay:1.2s">
    <%= helpers.svg "tabler/outline/heart", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-6 start-1/3 -rotate-6 text-green-400/40" style="animation-duration:3.2s;animation-delay:1.6s">
    <%= helpers.svg "tabler/outline/leaf", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-4 end-5 rotate-12 text-violet-400/40" style="animation-duration:4.8s;animation-delay:2.0s">
    <%= helpers.svg "tabler/outline/sparkles", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float top-3 end-10 -rotate-6 text-orange-400/40" style="animation-duration:3.6s;animation-delay:2.4s">
    <%= helpers.svg "tabler/outline/rocket", class: "size-4" %>
  </span>
  <span aria-hidden="true" class="grid-card__icon grid-card__icon--float bottom-3 end-12 rotate-6 text-teal-400/40" style="animation-duration:4.4s;animation-delay:2.8s">
    <%= helpers.svg "tabler/outline/diamond", class: "size-4" %>
  </span>

  <%= svg Avo.configuration.branding.placeholder, class: "relative mx-auto h-20 text-content-secondary" %>
</div>
