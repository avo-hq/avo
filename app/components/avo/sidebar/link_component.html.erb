<% if @path.present? %>
  <%= link_caller.send link_method, @path, class: "sidebar__link", active: @active, target: @target, data: @data, **@args do %>
    <%= helpers.svg @icon, class: "sidebar__link__icon" if @icon.present? %>
    <%= @label %>
    <% if @target == :_blank %>
      <%= helpers.svg('heroicons/outline/external-link', class: 'sidebar__link__external-icon') %>
    <% end %>
  <% end %>
<% else %>
  <%= content_tag :div, class: classes, active: @active, target: @target, data: @data do %>
    <%= helpers.svg @icon, class: "sidebar__link__icon" if @icon.present? %>
    <%= @label %>
  <% end %>
<% end %>
