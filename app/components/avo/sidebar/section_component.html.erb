<%= tag.div class: "sidebar-section", data: data do %>
  <% if item.name.present? %>
    <% if collapsable %>
      <button
        type="button"
        class="sidebar-section__header justify-between"
        data-action="click->menu#triggerCollapse"
        data-menu-target="trigger"
        aria-expanded="<%= !collapsed %>"
      >
        <span><%= item.name %></span>
        <span class="sidebar-section__icon sidebar-icon mt-1 <%= 'sidebar-icon--collapsed' if collapsed %>"
          data-menu-target="svg"
        >
          <%= helpers.svg 'heroicons/outline/chevron-down' %>
        </span>
      </button>
    <% else %>
      <div class="sidebar-section__header">
        <%= helpers.svg icon, class: "sidebar-section__icon sidebar-icon  mt-1" if icon.present? %>
        <span><%= item.name %></span>
      </div>
    <% end %>
  <% end %>

  <%= content_tag :div,
    hidden: collapsed,
    class: "sidebar-section__items",
    data: {
      menu_target: :items,
    } do %>
    <% @items.each do |item| %>
      <%= render Avo::Sidebar::ItemSwitcherComponent.new item: item %>
    <% end %>
  <% end %>
<% end %>
