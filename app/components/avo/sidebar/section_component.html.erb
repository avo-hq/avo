<%= tag.div class: "sidebar-section", data: data do %>
  <%= render Avo::Sidebar::HeadingComponent.new(
    title: item.name,
    icon: icon,
    collapsable: collapsable,
    collapsed: collapsed
  ) %>

  <%= content_tag :div,
    hidden: collapsed,
    class: "sidebar-section__items",
    data: {
      menu_target: :items,
    } do %>
    <% @items.each do |item| %>
      <%= render Avo::Sidebar::ItemSwitcherComponent.new item: item %>
    <% end %>
  <% end %>
<% end %>
