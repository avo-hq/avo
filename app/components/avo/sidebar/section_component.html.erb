<%= tag.div class: "sidebar__section", data: do %>
  <%= render Avo::Sidebar::HeadingComponent.new label: item.name, icon: helpers.svg(icon, class: ""), collapsable: item.collapsable, collapsed: collapsed, key: key %>
  <%= content_tag :div, class: "sidebar__section__items",
    hidden: collapsed,
    data: {
      menu_target: :items,
    } do %>
    <% @items.each do |item| %>
      <%= render Avo::Sidebar::ItemSwitcherComponent.new item: item %>
    <% end %>
  <% end %>
<% end %>
