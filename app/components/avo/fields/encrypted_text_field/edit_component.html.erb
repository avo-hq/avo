<%= field_wrapper(**field_wrapper_args) do %>
  <%# Don't prefill encrypted values to avoid exposing them in HTML source %>
  <%# Empty field means "leave unchanged"; only submit if user types new value %>
  <%= form.text_field @field.id,
    value: nil,
    class: classes("w-full"),
    data: @field.get_html(:data, view: view, element: :input).merge(
      controller: "encrypted-field-edit",
      encrypted_field_edit_target: "input"
    ),
    disabled: disabled?,
    placeholder: @field.placeholder || "Leave blank to keep current value",
    style: @field.get_html(:style, view: view, element: :input),
    autocomplete: "off"
  %>
  <p class="text-xs text-gray-500 mt-1">
    Leave empty to keep the existing encrypted value unchanged.
  </p>
<% end %>
