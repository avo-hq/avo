<%= content_tag :div, class: class_names("state", "state--frame-load-failed", @classes) do %>
  <% if @show_illustration %>
    <div class="state__illustration" aria-hidden="true">
      <% document_cards.each do |position| %>
        <div class="<%= class_names("state__document", "state__document--#{position}") %>">
          <div class="state__document-body">
            <div class="state__document-lines">
              <span class="state__document-line"></span>
              <span class="state__document-line"></span>
              <span class="state__document-line"></span>
              <span class="state__document-line"></span>
              <span class="state__document-line state__document-line--short"></span>
            </div>
          </div>
        </div>
      <% end %>

      <div class="state__magnifier">
        <%= helpers.svg "tabler/outline/zoom", class: "state__magnifier-icon" %>
      </div>
    </div>
  <% end %>

  <p class="state__message"><%= t 'avo.failed_to_load' %>: <strong><%= @frame %></strong></p>

  <% if Rails.env.development? && @src.present? %>
    <p class="state__note">
      Follow <%= link_to "this link", @src, target: "_blank", rel: "noopener", class: "state__link" %> for more details about the issue and how to fix it.
    </p>
  <% end %>
<% end %>
