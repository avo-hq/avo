  <%# ========================================= Surface matrix %>
  <div class="space-y-3">
    <h2 class="text-lg font-semibold">Surface matrix</h2>
    <p class="text-sm text-content-secondary">
      Same focusables rendered on four surfaces. Tab through each column and verify the
      info-colored ring reads clearly against each background. Toggle dark mode (DevTools
      → Rendering → <code>prefers-color-scheme: dark</code>) and repeat.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% [
          { label: "Primary",        bg: "bg-primary",    border: "border border-tertiary", text: nil },
          { label: "Secondary",      bg: "bg-secondary",  border: nil,                     text: nil },
          { label: "Tertiary",       bg: "bg-tertiary",   border: nil,                     text: nil },
          { label: "Blue-500 fill",  bg: "bg-blue-500",   border: nil,                     text: "text-white" }
        ].each do |s| %>
        <div class="<%= [s[:bg], s[:border], s[:text]].compact.join(" ") %> rounded-lg p-4 space-y-3">
          <div class="text-xs font-semibold"><%= s[:label] %></div>
          <%= render Avo::ButtonComponent.new(style: :primary) { "Button" } %>
          <input type="text" class="input-field w-full" placeholder="Input">
          <div><a href="#focus-audit">Link text</a></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ========================================= Inset validation %>
  <div class="space-y-3">
    <h2 class="text-lg font-semibold">Inset ring — validation</h2>
    <p class="text-sm text-content-secondary">
      Focusable inside an <code>overflow: hidden</code> wrapper. With the outward default
      the ring would be clipped; the inset offset keeps it fully visible.
    </p>
    <div class="rounded-lg border border-tertiary overflow-hidden max-w-sm">
      <button type="button" class="w-full text-start px-3 py-2 bg-primary hover:bg-secondary" style="outline-offset: var(--focus-outline-offset-inset);">
        Clipped-parent item (inset offset applied inline)
      </button>
    </div>
  </div>

  <div class="space-y-2 text-sm">
    <div class="font-semibold">Legend</div>
    <div class="flex items-center gap-2">
      <span class="inline-block size-3 rounded bg-warning/40 border border-warning"></span>
      <span class="text-content-secondary">
        Historical marker (pre-refactor). Row documented a component that used an ad-hoc
        <code>focus:ring-*</code>, <code>outline</code>, or custom <code>box-shadow</code>
        instead of the unified token. All such rows now route through the global
        <code>:focus-visible</code> rule in <code>focus.css</code>.
      </span>
