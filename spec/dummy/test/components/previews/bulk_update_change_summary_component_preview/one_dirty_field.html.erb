<%# Hand-built variant simulating what the Stimulus controller would render
    once one dirty key arrives. Useful for visual review of the populated state
    without driving the JS. %>
<div class="bulk-update-change-summary"
     data-bulk-update-form-target="changeSummary"
     data-records-count="47"
     aria-live="polite">
  <span class="bulk-update-change-summary__icon">
    <%= svg "tabler/outline/list-check", class: "size-5" %>
  </span>
  <div class="bulk-update-change-summary__body">
    <p class="bulk-update-change-summary__title">
      Set <strong>stage</strong>=<strong>success</strong> on <strong>47</strong> records.
    </p>
  </div>
</div>
